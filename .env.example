# Get these from https://dashboard.clerk.com/
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_publishable_key
CLERK_SECRET_KEY=your_secret_key

# Your Clerk Frontend API URL
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Secretary-Service (Video/Text-Transformation)
# SECRETARY_SERVICE_URL=https://your-secretary.example
# SECRETARY_SERVICE_API_KEY=
# Optional: pro Bibliothek unter Einstellungen → Transformation (benutzerdefinierte Verbindung).

# Azure Blob (Ingestion / Medien) — globaler Fallback, wenn die Library keine eigenen Werte hat
# (Einstellungen → Story → Abschnitt „Binary Storage“).
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_CONTAINER_NAME=

# External-Jobs: mehrere App-Instanzen mit derselben MongoDB — je Instanz eigene ID,
# damit Worker nur eigene Jobs claimen. Ohne Variable: Web/CLI nutzen Pool "default";
# Electron legt automatisch eine persistente ID unter userData an (siehe electron/main.js).
# JOBS_WORKER_POOL_ID=knowledge-scout-desktop-a

# Erfassung (POST /api/submissions): Groessen-Limits gegen Dev-OOM bei der
# Datei-/Ordner-Erfassung. Ueberschreitung -> HTTP 413 (kein Crash). Werte in Bytes;
# Defaults: 100 MiB pro Datei, 250 MiB Summe. Nur positive Ganzzahlen erlaubt.
# SUBMISSION_MAX_FILE_BYTES=104857600
# SUBMISSION_MAX_TOTAL_BYTES=262144000

# Electron Desktop: Teams stream.aspx → Graph (delegiert, Scope Files.Read)
# Öffentliche Client-ID aus Azure AD; Redirect-URI für Desktop/Loopback registrieren (z. B. http://localhost).
# ELECTRON_MSAL_CLIENT_ID=
# Optional: Tenant-GUID oder "organizations" (Default)
# ELECTRON_MSAL_TENANT_ID=organizations

# Root-Landingpage pro Domain (Variante B): JSON-Objekt Domain -> Library-Slug.
# Die gemappte Domain rendert unter `/` shell-frei die Website-Landingpage IHRER
# Library; nicht gemappte Domains (z. B. knowledgescout.org) zeigen unveraendert
# die Uebersicht bzw. die globale rootLibrarySlug-Config. Leer/ungesetzt = aus.
# Ungueltiges JSON wird geloggt und ignoriert (kein stiller Fallback).
# PUBLIC_DOMAIN_LIBRARY_MAP={"oldiesforfuture.org":"oldiesforfuture"}